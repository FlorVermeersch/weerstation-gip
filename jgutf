<!DOCTYPE html>
<html>
<head>
  <title>Weerstation</title>

  <style>
    body {
      font-family: Arial;
      background: #e6f2ff;
      margin: 0;
      padding: 20px;
      text-align: center;
    }

    h1 {
      margin-bottom: 20px;
    }

    .container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      max-width: 900px;
      margin: auto;
    }

    .box {
      background: white;
      padding: 10px;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    iframe {
      width: 100%;
      height: 260px;
      border: none;
    }

    .titel {
      font-weight: bold;
      margin-bottom: 5px;
    }
  </style>
</head>

<body>

<h1>Live Weerstation</h1>

<div class="container">

  <div class="box">
    <div class="titel">UV</div>
    <iframe src="https://thingspeak.com/channels/3293235/charts/1?dynamic=true&results=60&update=15"></iframe>
  </div>

  <div class="box">
    <div class="titel">Licht</div>
    <iframe src="https://thingspeak.com/channels/3293235/charts/2?dynamic=true&results=60&update=15"></iframe>
  </div>

  <div class="box">
    <div class="titel">Temperatuur</div>
    <iframe src="https://thingspeak.com/channels/3293235/charts/3?dynamic=true&results=60&update=15"></iframe>
  </div>

  <div class="box">
    <div class="titel">Luchtvochtigheid</div>
    <iframe src="https://thingspeak.com/channels/3293235/charts/4?dynamic=true&results=60&update=15"></iframe>
  </div>

  <div class="box">
    <div class="titel">Luchtdruk</div>
    <iframe src="https://thingspeak.com/channels/3293235/charts/5?dynamic=true&results=60&update=15"></iframe>
  </div>

  <div class="box">
    <div class="titel">Windrichting</div>
    <iframe src="https://thingspeak.com/channels/3293235/charts/6?dynamic=true&results=60&update=15"></iframe>
  </div>

</div>

</body>
</html>
